# Fichier d'exemple des variables d'environnement
# Copiez ce fichier en .env et modifiez les valeurs

# Clé secrète pour Flask (OBLIGATOIRE EN PRODUCTION)
# Générez-en une avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez_cette_cle_secrete_par_une_longue_chaine_aleatoire

# Configuration Redis (pour sessions partagées en production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Environnement Flask
FLASK_ENV=production
# Pour développement, utilisez: FLASK_ENV=development

# Configuration de l'application
MAX_IMAGES_PER_CLIENT=3
THUMBNAIL_SIZE=200

# Optionnel: Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
